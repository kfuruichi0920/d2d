{
  "$id": "d2d://schemas/llm-candidate-set",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM 候補セット出力",
  "description": "LLM-045: 正規化テキスト・設計要素候補・関係候補・警告を含む構造化 JSON",
  "type": "object",
  "required": ["elements", "relations"],
  "additionalProperties": true,
  "properties": {
    "normalized_text": { "type": ["string", "null"] },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["temp_id", "category", "title"],
        "additionalProperties": true,
        "properties": {
          "temp_id": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "pattern": "^model_[a-z][a-z0-9_]*$" },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": ["string", "null"] },
          "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "evidence": { "type": ["string", "null"] }
        }
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from_temp_id", "to_temp_id", "relation_type"],
        "additionalProperties": true,
        "properties": {
          "from_temp_id": { "type": "string", "minLength": 1 },
          "to_temp_id": { "type": "string", "minLength": 1 },
          "relation_type": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "rationale": { "type": ["string", "null"] },
          "attributes": { "type": ["object", "null"] }
        }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
